---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import Footer from "../../components/marketing/Footer.astro";
import {
  formatBlogDate,
  getBlogDate,
  getBlogPosts,
  getBlogReadTime,
  getBlogSlug,
} from "../../lib/blog";
import "../../styles/blog-parity.css";

const posts = await getBlogPosts();
const siteUrl = "https://www.brandklip.com";
const blogBreadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: `${siteUrl}/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: `${siteUrl}/blog`,
    },
  ],
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(blogBreadcrumbJsonLd)} />

<MarketingLayout
  title="Blogs"
  description="Deep dives on UGC, creator workflows, and performance marketing for D2C brands."
  canonicalPath="/blog"
>
  <main class="blog-page">
    <section class="blog-container">
      <p class="blog-kicker">Blogs</p>
      <h1 class="blog-title">BrandKlip Insights</h1>
      <p class="blog-subtitle">
        Deep dives on UGC, creator workflows, and performance marketing for D2C brands.
      </p>

      <div class="blog-list">
        {
          posts.map((post) => {
            const slug = getBlogSlug(post);
            const href = `/blog/${slug}`;
            return (
              <article class="blog-card">
                <p class="blog-card-meta">
                  {formatBlogDate(getBlogDate(post))} · {getBlogReadTime(post)}
                </p>
                <h2 class="blog-card-title">
                  <a href={href}>{post.data.title}</a>
                </h2>
                <p class="blog-card-description">
                  {post.data.description || "Read the full article."}
                </p>
                <a href={href} class="blog-card-cta">Read Article</a>
              </article>
            );
          })
        }
      </div>
    </section>
  </main>

  <Footer />
</MarketingLayout>
