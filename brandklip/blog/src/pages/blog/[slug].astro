---
import { render, type CollectionEntry } from "astro:content";
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import Footer from "../../components/marketing/Footer.astro";
import {
  formatBlogDate,
  getBlogDate,
  getBlogPosts,
  getBlogReadTime,
  getBlogSlug,
} from "../../lib/blog";
import "../../styles/blog-parity.css";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({
    params: { slug: getBlogSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content } = await render(post);
const slug = getBlogSlug(post);

const siteUrl = "https://www.brandklip.com";

const blogPostingJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: getBlogDate(post).toISOString(),
  author: {
    "@type": "Organization",
    name: post.data.authors?.[0] || "BrandKlip"
  }
};

const blogBreadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: `${siteUrl}/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: `${siteUrl}/blog`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: `${siteUrl}/blog/${slug}`,
    }
  ],
};
---

<MarketingLayout
  title={post.data.title}
  description={post.data.description || "BrandKlip blog post."}
  canonicalPath={`/blog/${slug}`}
  ogType="article"
  articleDate={getBlogDate(post).toISOString()}
  jsonLd={[blogPostingJsonLd, blogBreadcrumbJsonLd]}
>
  <main class="blog-page">
    <article class="blog-container" style="max-width: 52rem;">
      <a href="/blog" class="blog-back-link">← Back to Blogs</a>

      <header class="blog-post-header">
        <p class="blog-card-meta">
          {formatBlogDate(getBlogDate(post))} · {getBlogReadTime(post)}
        </p>
        <h1 class="blog-title" style="font-size: clamp(1.9rem, 4.3vw, 2.75rem); margin-top: 0.75rem;">
          {post.data.title}
        </h1>
        <p class="blog-subtitle" style="margin-top: 0.8rem; max-width: 100%;">
          {post.data.description || ""}
        </p>
      </header>

      <section class="blog-content">
        <Content />
      </section>
    </article>
  </main>

  <Footer />
</MarketingLayout>
