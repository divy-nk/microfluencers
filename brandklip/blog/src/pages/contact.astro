---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Footer from "../components/marketing/Footer.astro";
---

<MarketingLayout
  title="Contact"
  description="Get in touch with BrandKlip for support, partnerships, or media inquiries."
  canonicalPath="/contact"
>
  <section class="relative isolate overflow-hidden">
    <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 h-[36rem] bg-[radial-gradient(85%_70%_at_8%_12%,rgba(34,197,94,0.18),transparent_68%),radial-gradient(62%_58%_at_92%_8%,rgba(13,13,13,0.08),transparent_70%)]"></div>
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_bottom,rgba(255,255,255,0.42),rgba(249,250,251,0.92)_44%,rgba(249,250,251,1))]"></div>

    <section class="relative z-10 mx-auto max-w-6xl grid grid-cols-1 lg:grid-cols-[1.08fr_0.92fr] gap-5 md:gap-8 lg:gap-10 px-4 sm:px-6 pt-[7.35rem] md:pt-32 pb-16 md:pb-24">
      <section class="order-1 lg:order-1 rounded-[2rem] border border-black/10 bg-gradient-to-b from-[#d9f7eb]/65 via-[#f3fbf7] to-white p-6 md:p-10 shadow-[0_20px_55px_rgba(10,10,10,0.06)]" data-reveal>
        <p class="inline-flex items-center rounded-full border border-black/10 bg-white/85 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-[var(--ink-55)]">Contact</p>
        <h1 class="mt-4 text-[2rem] leading-[1.03] font-semibold tracking-tight text-[var(--brand-black)] sm:text-[2.55rem] md:text-[3.1rem]">Let's build something that works.</h1>
        <h2 class="mt-1 text-[1.95rem] leading-[1.03] font-semibold tracking-tight text-[var(--ink-45)] sm:text-[2.4rem] md:text-[2.95rem]">Fast replies. Clear next steps.</h2>
        <p class="mt-5 max-w-[40rem] text-[15px] leading-relaxed text-[var(--ink-60)] md:text-[1.05rem]">
          Questions, issues, partnership ideas, or press requests. Every message lands directly in the BrandKlip admin inbox.
        </p>

        <div class="mt-7 grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div class="rounded-2xl border border-black/10 bg-white/95 px-4 py-4">
            <p class="text-[11px] uppercase tracking-[0.16em] text-[var(--ink-45)] font-semibold">Email</p>
            <a href="mailto:hello@brandklip.com" class="mt-1 block break-all text-sm font-medium text-[var(--brand-black)] hover:underline">hello@brandklip.com</a>
          </div>
          <div class="hidden sm:block rounded-2xl border border-black/10 bg-white/95 px-4 py-4">
            <p class="text-[11px] uppercase tracking-[0.16em] text-[var(--ink-45)] font-semibold">Response Time</p>
            <p class="mt-1 text-sm font-medium text-[var(--brand-black)]">Usually within 24h</p>
          </div>
          <div class="hidden sm:block rounded-2xl border border-black/10 bg-white/95 px-4 py-4">
            <p class="text-[11px] uppercase tracking-[0.16em] text-[var(--ink-45)] font-semibold">Best For</p>
            <p class="mt-1 text-sm font-medium text-[var(--brand-black)]">Support, partnerships, media</p>
          </div>
        </div>
      </section>

      <section class="order-2 lg:order-2 rounded-[2rem] border border-black/10 bg-white/95 p-5 sm:p-6 md:p-8 shadow-[0_24px_60px_rgba(10,10,10,0.08)] backdrop-blur-sm" data-reveal>
        <div class="mb-5 border-b border-black/10 pb-4">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--ink-50)]">Send Message</p>
          <p class="mt-1 text-sm text-[var(--ink-60)]">We read every message and route it to the right team.</p>
        </div>

        <form id="contact-form" class="space-y-4 md:space-y-5" novalidate>
          <div>
            <label class="mb-1.5 block text-[13px] font-medium text-[var(--ink-65)]" for="name">Full name</label>
            <input id="name" name="name" type="text" autocomplete="name" class="h-12 w-full rounded-xl border border-black/10 bg-white px-3.5 text-[15px] text-[var(--brand-black)] outline-none transition focus:border-black/35 focus:ring-2 focus:ring-black/5" placeholder="Enter your name" required />
          </div>

          <div>
            <label class="mb-1.5 block text-[13px] font-medium text-[var(--ink-65)]" for="email">Email</label>
            <input id="email" name="email" type="email" autocomplete="email" inputmode="email" class="h-12 w-full rounded-xl border border-black/10 bg-white px-3.5 text-[15px] text-[var(--brand-black)] outline-none transition focus:border-black/35 focus:ring-2 focus:ring-black/5" placeholder="you@company.com" required />
          </div>

          <div>
            <label class="mb-1.5 block text-[13px] font-medium text-[var(--ink-65)]" for="subject">Subject (optional)</label>
            <input id="subject" name="subject" type="text" class="h-12 w-full rounded-xl border border-black/10 bg-white px-3.5 text-[15px] text-[var(--brand-black)] outline-none transition focus:border-black/35 focus:ring-2 focus:ring-black/5" placeholder="How can we help?" />
          </div>

          <div>
            <label class="mb-1.5 block text-[13px] font-medium text-[var(--ink-65)]" for="message">Message</label>
            <textarea id="message" name="message" maxlength="4000" class="min-h-[170px] w-full resize-y rounded-xl border border-black/10 bg-white px-3.5 py-3 text-[15px] text-[var(--brand-black)] outline-none transition focus:border-black/35 focus:ring-2 focus:ring-black/5" placeholder="Write your message here..." required></textarea>
            <div class="mt-1.5 flex justify-end text-xs text-[var(--ink-45)]"><span id="message-count">0</span>/4000</div>
          </div>

          <div class="sticky bottom-3 z-10 md:static">
            <button id="submit-button" type="submit" class="inline-flex h-12 w-full items-center justify-center rounded-full bg-black px-5 text-[15px] font-semibold text-white transition hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-60">
              Send Message
            </button>
          </div>

          <p id="contact-feedback" class="text-sm text-[var(--ink-60)]" aria-live="polite"></p>
        </form>
      </section>
    </section>
  </section>

  <Footer />

  <script is:inline>
    const form = document.getElementById("contact-form");
    const messageField = document.getElementById("message");
    const messageCount = document.getElementById("message-count");
    const feedback = document.getElementById("contact-feedback");
    const submitButton = document.getElementById("submit-button");

    const contactEndpoint = "/api/contact";

    const setFeedback = (text, isError = false) => {
      if (!feedback) return;
      feedback.textContent = text;
      feedback.style.color = isError ? "#b91c1c" : "var(--ink-60)";
    };

    if (messageField && messageCount) {
      messageField.addEventListener("input", () => {
        messageCount.textContent = String(messageField.value.length);
      });
    }

    if (form && submitButton) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const name = (document.getElementById("name")?.value || "").trim();
        const email = (document.getElementById("email")?.value || "").trim();
        const subject = (document.getElementById("subject")?.value || "").trim();
        const message = (document.getElementById("message")?.value || "").trim();

        if (!name || !email || !message) {
          setFeedback("Please fill in your name, email, and message.", true);
          return;
        }

        submitButton.disabled = true;
        submitButton.textContent = "Sending...";
        setFeedback("");

        try {
          const response = await fetch(contactEndpoint, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ name, email, subject, message }),
          });

          const payload = await response.json().catch(() => ({}));

          if (!response.ok) {
            const errorMessage = payload?.error || "Could not send your message. Please try again.";
            setFeedback(errorMessage, true);
            return;
          }

          setFeedback("Message sent. Our team will get back to you soon.");
          form.reset();
          if (messageCount) messageCount.textContent = "0";
        } catch (error) {
          setFeedback("Could not send your message. Please try again.", true);
        } finally {
          submitButton.disabled = false;
          submitButton.textContent = "Send Message";
        }
      });
    }
  </script>
</MarketingLayout>
