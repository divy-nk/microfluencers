---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Footer from "../components/marketing/Footer.astro";
---

<MarketingLayout
  title="Page Not Found"
  description="The page you are looking for does not exist."
  canonicalPath="/404"
>
  <section class="relative z-10 min-h-[70vh] flex items-center justify-center px-6 py-24">
    <div class="w-full max-w-3xl text-center" data-reveal>
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[var(--ink-45)] mb-5">Error 404</p>
      <h1 class="text-4xl md:text-6xl font-semibold tracking-tight text-[var(--brand-black)] mb-6 leading-tight">
        This page is off-brief.
      </h1>
      <p class="text-lg text-[var(--ink-60)] max-w-2xl mx-auto mb-10">
        We could not find the page you requested. Head back to homepage to launch your next campaign.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/" class="hero-cta hero-cta-static">Back to Homepage</a>
        <a href="/contact" class="hero-cta" style="background: transparent; color: var(--brand-black); border: 1px solid var(--line-soft);">Contact Support</a>
      </div>
    </div>
  </section>

  <Footer />
</MarketingLayout>
