---
const steps = [
  {
    num: 1,
    title: "Build your profile",
    desc: "Set your niche, platforms, languages, and sample videos so brands can find the right fit.",
    label: "Profile",
    offset: 0,
  },
  {
    num: 2,
    title: "Apply to matched drops",
    desc: "Browse campaigns aligned to your content style and apply only to briefs you want.",
    label: "Apply",
    offset: 60,
  },
  {
    num: 3,
    title: "Purchase and create",
    desc: "Buy the product from the brand store and create content exactly as the brief requests.",
    label: "Create",
    offset: 20,
  },
  {
    num: 4,
    title: "Submit proof and video",
    desc: "Upload purchase proof and your final video to BrandKlip for brief-based review.",
    label: "Submit",
    offset: 80,
  },
  {
    num: 5,
    title: "Get reimbursed fast",
    desc: "Once verified, escrow-backed payment is released to your UPI or bank account.",
    label: "Get paid",
    offset: 10,
  },
];
---

<section class="relative w-full py-20 sm:py-24 md:py-28 bg-transparent overflow-visible md:overflow-hidden">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-10 md:mb-14" data-reveal>
      <div class="pill-animated brand-benefits-pill mb-3">
        <span class="brand-benefits-pill__icon" aria-hidden="true">✦</span>
        <span class="brand-benefits-pill__label brand-benefits-pill__label--caps">How It Works</span>
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-foreground mb-3">Creator collabs that pay on time.</h2>
      <p class="text-sm md:text-base text-[var(--ink-55)]">From profile to payout in five clear steps.</p>
    </div>

    <div class="hidden md:block relative h-[360px]" data-reveal>
      <svg class="absolute inset-0 z-0 w-full h-full pointer-events-none" viewBox="0 0 690 200" preserveAspectRatio="none" aria-hidden="true">
        <path id="hiw-track-creators" d="M 54 100 C 130 155, 230 178, 340 122 C 450 66, 560 144, 636 100" fill="none" stroke="rgba(13,13,13,0.14)" stroke-width="1.5" stroke-dasharray="5 5" />
        <circle r="4" fill="var(--brand-black)">
          <animateMotion dur="4s" repeatCount="indefinite" path="M 54 100 C 130 155, 230 178, 340 122 C 450 66, 560 144, 636 100" />
        </circle>
        <circle r="4" fill="var(--brand-black)">
          <animateMotion dur="4s" begin="1.33s" repeatCount="indefinite" path="M 54 100 C 130 155, 230 178, 340 122 C 450 66, 560 144, 636 100" />
        </circle>
        <circle r="4" fill="var(--brand-black)">
          <animateMotion dur="4s" begin="2.66s" repeatCount="indefinite" path="M 54 100 C 130 155, 230 178, 340 122 C 450 66, 560 144, 636 100" />
        </circle>
      </svg>

      <div class="absolute inset-0 z-10 flex items-start justify-between px-2">
        {steps.map((step) => (
          <div class="flex flex-col items-center flex-1 min-w-0" style={`margin-top: ${step.offset}px;`}>
            <article class="hiw-card rounded-2xl border border-[color:var(--line-soft)] bg-[var(--white)] p-4 w-[130px] shadow-[0_8px_22px_rgba(15,23,42,0.08)]">
              <div class="h-9 w-9 rounded-xl border border-[color:var(--line-soft)] bg-[color:rgba(200,240,224,0.25)] flex items-center justify-center mb-3 text-xs font-bold text-[var(--brand-black)]">{step.num}</div>
              <h3 class="text-[11px] font-semibold text-[var(--brand-black)] leading-[1.3]">{step.title}</h3>
              <p class="text-[10px] text-[var(--ink-50)] mt-1.5 leading-[1.35]">{step.desc}</p>
            </article>

            <div class="mt-2.5 flex flex-col items-center gap-1.5">
              <div class="h-5 w-5 rounded-full border border-[color:var(--line-soft)] bg-[var(--white)] text-[10px] font-semibold text-[var(--ink-55)] flex items-center justify-center">{step.num}</div>
              <p class="text-[10px] text-[var(--ink-45)] text-center max-w-[92px] leading-[1.3]">{step.label}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="md:hidden px-0.5 sm:px-1" data-reveal>
      <div class="grid grid-cols-1 gap-3">
        {steps.map((step, index) => (
          <div class="hiw-mobile-item">
            <article class="hiw-mobile-card rounded-2xl border border-[color:var(--line-soft)] bg-[var(--white)] p-4 sm:p-5">
              <div class="hiw-mobile-card__number h-9 w-9 rounded-xl border border-[color:var(--line-soft)] bg-[color:rgba(200,240,224,0.28)] flex items-center justify-center mb-3 text-sm font-semibold text-[var(--ink-70)] transition-colors duration-250">{step.num}</div>
              <h3 class="text-[1.05rem] font-semibold text-[var(--brand-black)] tracking-tight leading-snug">{step.title}</h3>
              <p class="text-sm text-[var(--ink-55)] leading-relaxed mt-1.5">{step.desc}</p>
            </article>
            {index < steps.length - 1 && (
              <div class="hiw-mobile-connector" aria-hidden="true">
                <div class="hiw-mobile-connector-segment" />
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  #hiw-track-creators {
    opacity: 0.6;
  }

  .hiw-card {
    animation: hiw-float 3.5s ease-in-out infinite;
    transform-origin: center;
    position: relative;
    z-index: 2;
  }

  @media (hover: hover) and (pointer: fine) {
    .hiw-card:hover {
      transform: translateY(-6px) scale(1.03);
      box-shadow: 0 14px 30px rgba(15, 23, 42, 0.14);
      transition: transform 220ms ease, box-shadow 220ms ease;
    }

    .hiw-mobile-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
      border-color: rgba(13, 13, 13, 0.12);
      background: rgba(255, 255, 255, 1);
    }

    .hiw-mobile-card:hover .hiw-mobile-card__number {
      background: rgba(200, 240, 224, 0.5);
      border-color: rgba(34, 197, 94, 0.2);
      color: var(--brand-black);
    }
  }

  .hiw-mobile-card {
    position: relative;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
    transform: translateY(0);
    transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 300ms cubic-bezier(0.22, 1, 0.36, 1), border-color 220ms ease;
  }

  .hiw-mobile-connector {
    display: flex;
    justify-content: center;
    padding: 6px 0 2px;
  }

  .hiw-mobile-connector-segment {
    width: 2px;
    height: 24px;
    border-radius: 2px;
    background: linear-gradient(180deg, #22C55E, #86efac);
    transform-origin: top center;
  }

  @media (max-width: 767px) and (prefers-reduced-motion: no-preference) {
    .hiw-mobile-item .hiw-mobile-card {
      opacity: 0;
      animation: hiwMobileFadeUp 0.5s ease-out forwards;
    }

    .hiw-mobile-item:nth-child(2) .hiw-mobile-card {
      animation-delay: 0.1s;
    }

    .hiw-mobile-item:nth-child(3) .hiw-mobile-card {
      animation-delay: 0.2s;
    }

    .hiw-mobile-item:nth-child(4) .hiw-mobile-card {
      animation-delay: 0.3s;
    }

    .hiw-mobile-item:nth-child(5) .hiw-mobile-card {
      animation-delay: 0.4s;
    }

    .hiw-mobile-item .hiw-mobile-connector-segment {
      transform: scaleY(0);
      animation: hiwMobileLineReveal 0.35s ease-out forwards;
      animation-delay: 0.08s;
    }

    .hiw-mobile-item:nth-child(2) .hiw-mobile-connector-segment {
      animation-delay: 0.18s;
    }

    .hiw-mobile-item:nth-child(3) .hiw-mobile-connector-segment {
      animation-delay: 0.28s;
    }

    .hiw-mobile-item:nth-child(4) .hiw-mobile-connector-segment {
      animation-delay: 0.38s;
    }
  }

  .absolute .flex > :nth-child(2) .hiw-card {
    animation-delay: 0.45s;
  }

  .absolute .flex > :nth-child(3) .hiw-card {
    animation-delay: 0.9s;
  }

  .absolute .flex > :nth-child(4) .hiw-card {
    animation-delay: 1.35s;
  }

  .absolute .flex > :nth-child(5) .hiw-card {
    animation-delay: 1.8s;
  }

  @keyframes hiw-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-5px);
    }
  }

  @keyframes hiwMobileFadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hiwMobileLineReveal {
    from {
      transform: scaleY(0);
      opacity: 0;
    }
    to {
      transform: scaleY(1);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hiw-card {
      animation: none;
    }

    .hiw-mobile-card {
      animation: none;
      opacity: 1;
    }

    .hiw-mobile-connector-segment {
      transform: scaleY(1);
    }
  }
</style>