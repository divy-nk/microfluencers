---
type ComparisonColumn = {
  label: string;
  helper?: string;
  highlighted?: boolean;
};

type ComparisonRow = {
  feature: string;
  values: Array<string | boolean>;
};

type Props = {
  badge: string;
  title: string;
  subtitle: string;
  columns: ComparisonColumn[];
  rows: ComparisonRow[];
  ctaLabel: string;
  ctaHref: string;
};

const { badge, title, subtitle, columns, rows, ctaLabel, ctaHref } = Astro.props;
const highlightedBg = "var(--hero-mint-start)";
const highlightedColumnWidth = "260px";

const isBrandKlipColumn = (column: ComparisonColumn) =>
  Boolean(column.highlighted) || column.label.trim().toLowerCase() === "brandklip";

const isPayBeforeContentRow = (feature: string) =>
  feature.trim().toLowerCase() === "pay before content?";

const isApprovalFairnessRow = (feature: string) =>
  feature.trim().toLowerCase() === "approval fairness";

const getColumnCellClass = (column: ComparisonColumn | undefined) =>
  column?.highlighted ? "px-4" : "px-6";

const getColumnCellStyle = (column: ComparisonColumn | undefined, includeRadius = false) => {
  if (!column?.highlighted) {
    return undefined;
  }

  return {
    backgroundColor: highlightedBg,
    width: highlightedColumnWidth,
    maxWidth: highlightedColumnWidth,
    ...(includeRadius
      ? {
          borderTopLeftRadius: "30px",
          borderTopRightRadius: "30px",
        }
      : {}),
  };
};

const getHighlightedBottomCellStyle = (column: ComparisonColumn) =>
  column.highlighted
    ? {
        backgroundColor: highlightedBg,
        width: highlightedColumnWidth,
        maxWidth: highlightedColumnWidth,
        borderBottomLeftRadius: "30px",
        borderBottomRightRadius: "30px",
      }
    : undefined;

const normalizeCellValue = (feature: string, column: ComparisonColumn | undefined, value: string | boolean) => {
  if (!column) {
    return value;
  }
  if (isApprovalFairnessRow(feature) && /agency/i.test(column.label)) {
    return "No structure";
  }
  return value;
};

const renderValue = (value: string | boolean, highlighted: boolean, feature: string) => {
  if (typeof value === "boolean") {
    if (isPayBeforeContentRow(feature)) {
      return value ? "✓" : "✕";
    }
    return value ? (highlighted ? "✓" : "Yes") : (highlighted ? "-" : "No");
  }
  return value;
};
---

<section class="relative w-full py-16 md:py-20 bg-transparent">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8 md:mb-10">
      <div class="pill-animated brand-benefits-pill mb-3">
        <span class="brand-benefits-pill__icon" aria-hidden="true">✦</span>
        <span class="brand-benefits-pill__label brand-benefits-pill__label--caps">{badge}</span>
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-semibold tracking-tight text-[var(--brand-black)]">{title}</h2>
      <p class="mt-3 text-sm md:text-base text-[var(--ink-60)] max-w-3xl mx-auto">{subtitle}</p>
    </div>

    <div class="rounded-[1.8rem] border border-[color:var(--line-soft)] bg-[var(--white)] p-2.5 sm:p-3 md:p-5 shadow-[0_16px_38px_rgba(15,23,42,0.06)] overflow-hidden">
      <div class="md:hidden space-y-3 px-1 sm:px-1.5 pb-2">
        {rows.map((row) => (
          <article class="rounded-2xl border border-[color:var(--line-soft)] bg-[var(--white)] overflow-hidden">
            <div class="px-4 py-3 border-b border-[color:var(--line-faint)]">
              <h3 class="text-base font-semibold text-[var(--brand-black)]">{row.feature}</h3>
            </div>
            <div class="divide-y divide-[color:var(--line-faint)]">
              {columns.map((column, colIndex) => {
                const value = normalizeCellValue(row.feature, column, row.values[colIndex]);
                const highlighted = Boolean(column.highlighted);
                return (
                  <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-2.5 px-3.5 sm:px-4 py-3" style={highlighted ? { backgroundColor: "rgba(200, 240, 224, 0.42)" } : undefined}>
                    {
                      isBrandKlipColumn(column) ? (
                        <div class="inline-flex flex-wrap items-center gap-1.5 pr-2">
                          <img src="/logo-black.png" alt="BrandKlip" width="88" height="20" class="h-5 w-auto max-w-[7.5rem] shrink-0 object-contain" loading="lazy" decoding="async" />
                          <span class="text-sm sm:text-[15px] font-semibold text-[var(--brand-black)]" style='font-family: "Bricolage Grotesque", sans-serif;'>BrandKlip</span>
                        </div>
                      ) : (
                          <p class={`text-xs uppercase tracking-[0.08em] break-words ${highlighted ? "font-bold text-[var(--brand-black)]" : "font-semibold text-[var(--ink-55)]"}`}>{column.label}</p>
                      )
                    }
                    <div class="justify-self-end text-right">
                      {typeof value === "boolean" ? (
                        <span class={`inline-flex h-7 w-7 sm:h-8 sm:w-8 items-center justify-center rounded-full text-sm font-bold ${highlighted ? "bg-[var(--white)] text-[var(--brand-black)] shadow-[0_2px_8px_rgba(0,0,0,0.08)]" : "bg-[color:var(--line-faint)] text-[var(--ink-65)]"}`}>
                          {renderValue(value, highlighted, row.feature)}
                        </span>
                      ) : (
                          <span class={`inline-block max-w-[11.5rem] text-sm leading-snug break-words ${highlighted ? "font-semibold text-[var(--brand-black)]" : "font-medium text-[var(--ink-65)]"}`}>{value}</span>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </article>
        ))}

        <div class="rounded-[1.4rem] p-4 flex justify-center" style={{ backgroundColor: highlightedBg }}>
          <a href={ctaHref} class="inline-flex items-center whitespace-nowrap rounded-full bg-[var(--brand-black)] px-6 py-3 text-[11px] font-black uppercase tracking-[0.08em] text-[var(--white)] no-underline hover:bg-[color:var(--ink-90)] transition-colors">
            {ctaLabel}
          </a>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="comparison-table hidden md:table w-full min-w-[760px] border-separate border-spacing-0 text-left">
          <thead>
            <tr>
              <th class="px-4 py-5 text-[10px] uppercase tracking-[0.16em] text-[var(--ink-35)] font-black border-b border-[color:var(--line-soft)]" style='font-family: "Bricolage Grotesque", sans-serif;'>Feature</th>
              {columns.map((column) => (
                <th class={`${getColumnCellClass(column)} py-5 border-b border-[color:var(--line-soft)]`} style={getColumnCellStyle(column, true)}>
                  {
                    isBrandKlipColumn(column) ? (
                      <div class="inline-flex items-center gap-2.5">
                        <img src="/logo-black.png" alt="BrandKlip" width="124" height="28" class="h-7 w-auto object-contain" loading="lazy" decoding="async" />
                        <p class="text-[1.05rem] font-semibold text-[var(--brand-black)]" style='font-family: "Bricolage Grotesque", sans-serif;'>BrandKlip</p>
                      </div>
                    ) : (
                      <p class="text-xs uppercase tracking-[0.14em] font-black text-[var(--brand-black)]">{column.label}</p>
                    )
                  }
                  {column.helper && <p class="mt-1 text-[11px] font-medium text-[var(--ink-55)]">{column.helper}</p>}
                </th>
              ))}
            </tr>
          </thead>

          <tbody>
            {rows.map((row) => (
              <tr>
                <td class="px-4 py-4 text-sm font-semibold text-[var(--brand-black)] border-b border-[color:var(--line-faint)]" style='font-family: "Bricolage Grotesque", sans-serif;'>{row.feature}</td>
                {row.values.map((value, index) => (
                  <td class={`${getColumnCellClass(columns[index])} py-4 border-b border-[color:var(--line-faint)]`} style={getColumnCellStyle(columns[index])}>
                    {typeof normalizeCellValue(row.feature, columns[index], value) === "boolean" ? (
                      <span class={`status-icon inline-flex h-8 w-8 items-center justify-center rounded-full text-sm font-bold ${columns[index]?.highlighted ? "bg-[var(--white)] text-[var(--brand-black)] shadow-[0_2px_8px_rgba(0,0,0,0.08)]" : "bg-[color:var(--line-faint)] text-[var(--ink-65)]"}`}>
                        {renderValue(normalizeCellValue(row.feature, columns[index], value), Boolean(columns[index]?.highlighted), row.feature)}
                      </span>
                    ) : (
                      <span class="text-sm font-medium text-[var(--ink-65)]">{normalizeCellValue(row.feature, columns[index], value)}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))}

            <tr>
              <td class="px-4 py-5 border-b border-[color:var(--line-faint)]"></td>
              {columns.map((column) => (
                <td class={`${getColumnCellClass(column)} py-5 border-b border-[color:var(--line-faint)] text-center`} style={getHighlightedBottomCellStyle(column)}>
                  {column.highlighted && (
                    <a href={ctaHref} class="mx-auto inline-flex items-center whitespace-nowrap rounded-full bg-[var(--brand-black)] px-6 py-3 text-[11px] font-black uppercase tracking-[0.08em] text-[var(--white)] no-underline hover:bg-[color:var(--ink-90)] transition-colors">
                      {ctaLabel}
                    </a>
                  )}
                </td>
              ))}
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<script>
  const table = document.querySelector(".comparison-table");
  if (!table) {
    // no-op
  } else {
    const isDesktop = window.matchMedia("(min-width: 768px)").matches;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isTouchDevice =
      window.matchMedia("(pointer: coarse)").matches ||
      navigator.maxTouchPoints > 0;

    const rows = Array.from(table.querySelectorAll("tbody tr"));
    const icons = Array.from(table.querySelectorAll(".status-icon"));

    const showAll = () => {
      rows.forEach((row) => {
        if (row instanceof HTMLElement) {
          row.style.opacity = "1";
          row.style.transform = "none";
        }
      });

      icons.forEach((icon) => {
        if (icon instanceof HTMLElement) {
          icon.style.opacity = "1";
          icon.style.transform = "none";
        }
      });
    };

    if (!isDesktop || prefersReducedMotion || isTouchDevice) {
      showAll();
    } else {
      const initGsapTable = async () => {
        const gsapModule = await import("gsap");
        const stModule = await import("gsap/ScrollTrigger");
        const gsap = gsapModule.gsap || gsapModule.default || gsapModule;
        const ScrollTrigger = stModule.ScrollTrigger || stModule.default;

        if (!gsap || !ScrollTrigger) {
          showAll();
          return;
        }

        gsap.registerPlugin(ScrollTrigger);

        gsap.from(rows, {
          x: -22,
          autoAlpha: 0,
          duration: 0.52,
          stagger: 0.06,
          ease: "power2.out",
          clearProps: "opacity,transform,visibility",
          scrollTrigger: {
            trigger: table,
            start: "top 82%",
            once: true,
            fastScrollEnd: true,
          },
        });

        gsap.from(icons, {
          scale: 0.72,
          rotation: -16,
          autoAlpha: 0,
          duration: 0.38,
          stagger: 0.028,
          ease: "back.out(1.6)",
          clearProps: "opacity,transform,visibility",
          scrollTrigger: {
            trigger: table,
            start: "top 76%",
            once: true,
            fastScrollEnd: true,
          },
        });
      };

      initGsapTable();
    }
  }
</script>

<style>
  .comparison-table tbody tr {
    transition: background-color 0.2s ease;
  }

  .comparison-table tbody tr:hover {
    background: rgba(200, 240, 224, 0.1);
  }

  .comparison-table tbody tr:hover td {
    position: relative;
  }
</style>
