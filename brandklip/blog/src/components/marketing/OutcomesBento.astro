---
// Outcome-focused 1x4 grid showing tangible, MVP-accurate results
---

<section class="relative w-full py-16 md:py-20 bg-transparent">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="text-center mb-8 md:mb-12">
      <div class="pill-animated brand-benefits-pill mb-4">
        <span class="brand-benefits-pill__icon" aria-hidden="true">✦</span>
        <span class="brand-benefits-pill__label brand-benefits-pill__label--caps">What You Get</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-foreground">Real outcomes. Not promises.</h2>
      <p class="text-foreground/55 text-sm md:text-base mt-3 max-w-2xl mx-auto">Here's what you actually get when you run a campaign on BrandKlip.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
      <!-- Card 1: Pay-Per-Video Pricing -->
      <article class="outcome-card rounded-[1.5rem] border border-[color:var(--line-soft)] bg-[var(--white)] p-5 md:p-6 shadow-[0_10px_24px_rgba(15,23,42,0.04)] transition-all duration-300 ease-out">
        <div class="outcome-card__number h-10 w-10 rounded-xl border border-[color:var(--line-soft)] bg-[color:rgba(200,240,224,0.28)] flex items-center justify-center mb-4 text-[var(--ink-70)] text-sm font-semibold transition-colors duration-250">
          1
        </div>
        
        <h3 class="text-lg md:text-xl font-semibold tracking-tight text-foreground mb-2">You only pay per approved video</h3>
        <p class="text-sm text-foreground/60 leading-relaxed mb-5">Run 10 campaigns for 10 angles, or get 10 videos in one campaign. Full control over content strategy. No wasted budget on rejected submissions.</p>
        
        <!-- Visual: Price Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-3 rounded-xl bg-[color:rgba(200,240,224,0.2)] border border-[color:var(--line-soft)]">
          <span class="text-xs font-semibold text-[var(--ink-50)]">Per Video Pricing</span>
        </div>
      </article>

      <!-- Card 2: Campaign Tracking -->
      <article class="outcome-card rounded-[1.5rem] border border-[color:var(--line-soft)] bg-[var(--white)] p-5 md:p-6 shadow-[0_10px_24px_rgba(15,23,42,0.04)] transition-all duration-300 ease-out">
        <div class="outcome-card__number h-10 w-10 rounded-xl border border-[color:var(--line-soft)] bg-[color:rgba(200,240,224,0.28)] flex items-center justify-center mb-4 text-[var(--ink-70)] text-sm font-semibold transition-colors duration-250">
          2
        </div>
        
        <h3 class="text-lg md:text-xl font-semibold tracking-tight text-foreground mb-2">Track every campaign in real-time</h3>
        <p class="text-sm text-foreground/60 leading-relaxed mb-5">See applications, submissions, and approval rates as they happen. Know exactly where your campaign stands. No more chasing updates.</p>
        
        <!-- Visual: Mini Dashboard -->
        <div class="space-y-2">
          <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-[color:rgba(200,240,224,0.1)] border border-[color:var(--line-soft)]">
            <span class="text-xs font-medium text-[var(--ink-70)]">Applications</span>
            <span class="text-sm font-bold text-[var(--brand-black)]" data-metric="12">0</span>
          </div>
          <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-[color:rgba(200,240,224,0.1)] border border-[color:var(--line-soft)]">
            <span class="text-xs font-medium text-[var(--ink-70)]">Pending Review</span>
            <span class="text-sm font-bold text-[var(--brand-black)]" data-metric="3">0</span>
          </div>
          <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-[color:rgba(34,197,94,0.1)] border border-[color:rgba(34,197,94,0.2)]">
            <span class="text-xs font-medium text-[var(--ink-70)]">Approved</span>
            <span class="text-sm font-bold text-[var(--brand-green)]" data-metric="5">0</span>
          </div>
        </div>
      </article>

      <!-- Card 3: BrandKlip Verification -->
      <article class="outcome-card rounded-[1.5rem] border border-[color:var(--line-soft)] bg-[var(--white)] p-5 md:p-6 shadow-[0_10px_24px_rgba(15,23,42,0.04)] transition-all duration-300 ease-out">
        <div class="flex items-start justify-between mb-4">
          <div class="outcome-card__number h-10 w-10 rounded-xl border border-[color:var(--line-soft)] bg-[color:rgba(200,240,224,0.28)] flex items-center justify-center text-[var(--ink-70)] text-sm font-semibold transition-colors duration-250">
            3
          </div>
          <div class="text-xs font-semibold text-[var(--ink-50)] px-3 py-1.5 rounded-full bg-[color:rgba(200,240,224,0.2)] border border-[color:var(--line-soft)]">
            Quality Guaranteed
          </div>
        </div>
        
        <h3 class="text-lg md:text-xl font-semibold tracking-tight text-foreground mb-2">BrandKlip verifies for you</h3>
        <p class="text-sm text-foreground/60 leading-relaxed mb-5">Every submission is checked against your brief by our team. You get pre-approved, on-brief content. Focus on your business, not creator management.</p>
        
        <!-- Visual: Verification Steps -->
        <div class="flex items-center gap-2">
          <div class="flex-1 h-1.5 rounded-full bg-[color:rgba(200,240,224,0.2)]">
            <div class="h-full rounded-full bg-[color:rgba(34,197,94,0.6)]" data-progress-bar style="width: 0%"></div>
          </div>
          <div class="flex-1 h-1.5 rounded-full bg-[color:rgba(200,240,224,0.2)]">
            <div class="h-full rounded-full bg-[color:rgba(34,197,94,0.6)]" data-progress-bar style="width: 0%"></div>
          </div>
          <div class="flex-1 h-1.5 rounded-full bg-[color:rgba(200,240,224,0.2)]">
            <div class="h-full rounded-full bg-[color:rgba(34,197,94,0.6)]" data-progress-bar style="width: 0%"></div>
          </div>
        </div>
        <p class="text-xs text-[var(--ink-50)] mt-2 font-medium">3-step verification process</p>
      </article>

      <!-- Card 4: Reusable Assets -->
      <article class="outcome-card rounded-[1.5rem] border border-[color:var(--line-soft)] bg-[var(--white)] p-5 md:p-6 shadow-[0_10px_24px_rgba(15,23,42,0.04)] transition-all duration-300 ease-out">
        <div class="outcome-card__number h-10 w-10 rounded-xl border border-[color:var(--line-soft)] bg-[color:rgba(200,240,224,0.28)] flex items-center justify-center mb-4 text-[var(--ink-70)] text-sm font-semibold transition-colors duration-250">
          4
        </div>
        
        <h3 class="text-lg md:text-xl font-semibold tracking-tight text-foreground mb-2">Build reusable assets</h3>
        <p class="text-sm text-foreground/60 leading-relaxed mb-5">Full usage rights for all approved content. Use across Meta Ads, Amazon listings, website, and email.</p>
        
        <!-- Visual: Stats Grid -->
        <div class="grid grid-cols-2 gap-2 mb-3">
          <div class="p-3 rounded-lg bg-[color:rgba(200,240,224,0.15)] border border-[color:var(--line-soft)]">
            <p class="text-xl font-bold text-[var(--brand-black)] mb-0.5" data-counter="14">14</p>
            <p class="text-[10px] font-medium text-[var(--ink-60)]">Licensed videos</p>
          </div>
          <div class="p-3 rounded-lg bg-[color:rgba(200,240,224,0.15)] border border-[color:var(--line-soft)]">
            <p class="text-xl font-bold text-[var(--brand-black)] mb-0.5">∞</p>
            <p class="text-[10px] font-medium text-[var(--ink-60)]">Usage duration</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-1.5">
          <span class="text-[10px] px-2 py-1 rounded-md bg-[color:rgba(13,13,13,0.05)] text-[var(--ink-60)] font-medium">Meta Ads</span>
          <span class="text-[10px] px-2 py-1 rounded-md bg-[color:rgba(13,13,13,0.05)] text-[var(--ink-60)] font-medium">Amazon</span>
          <span class="text-[10px] px-2 py-1 rounded-md bg-[color:rgba(13,13,13,0.05)] text-[var(--ink-60)] font-medium">Website</span>
          <span class="text-[10px] px-2 py-1 rounded-md bg-[color:rgba(13,13,13,0.05)] text-[var(--ink-60)] font-medium">Email</span>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  // Intersection Observer for scroll-triggered animations
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const card = entry.target;
          
          // Card 2: Animate dashboard metrics counting up
          if (card.classList.contains('outcome-card') && card.querySelector('[data-metric]')) {
            const metrics = card.querySelectorAll('[data-metric]');
            metrics.forEach((metric, index) => {
              const metricElement = metric as HTMLElement;
              const target = parseInt(metricElement.getAttribute('data-metric') || '0');
              animateCounter(metricElement, 0, target, 800, index * 150);
            });
          }
          
          // Card 3: Animate progress bars filling
          if (card.classList.contains('outcome-card')) {
            const bars = card.querySelectorAll('[data-progress-bar]');
            bars.forEach((bar, index) => {
              setTimeout(() => {
                (bar as HTMLElement).style.width = '100%';
              }, index * 150);
            });
          }
          
          // Card 4: Animate stat counters
          if (card.classList.contains('outcome-card')) {
            const counter = card.querySelector('[data-counter]');
            if (counter) {
              const counterElement = counter as HTMLElement;
              const target = parseInt(counterElement.getAttribute('data-counter') || '0');
              animateCounter(counterElement, 0, target, 1000, 0);
            }
          }
          
          observer.unobserve(card);
        }
      });
    }, { threshold: 0.2 });
    
    // Observe all cards
    document.querySelectorAll('.outcome-card').forEach(card => observer.observe(card));
  }
  
  // Counter animation function
  function animateCounter(element: HTMLElement, start: number, end: number, duration: number, delay: number) {
    setTimeout(() => {
      const startTime = performance.now();
      const animate = (currentTime: number) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        
        // easeOutQuart easing
        const easeProgress = 1 - Math.pow(1 - progress, 4);
        const current = Math.floor(start + (end - start) * easeProgress);
        
        element.textContent = current.toString();
        
        if (progress < 1) {
          requestAnimationFrame(animate);
        }
      };
      requestAnimationFrame(animate);
    }, delay);
  }
</script>

<style>
  /* Apple-inspired refined animations - subtle and premium */
  .outcome-card {
    position: relative;
  }

  .outcome-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(15, 23, 42, 0.08);
    border-color: rgba(13, 13, 13, 0.12);
  }

  .outcome-card:hover .outcome-card__number {
    background: rgba(200, 240, 224, 0.5);
    border-color: rgba(34, 197, 94, 0.2);
    color: var(--brand-black);
  }

  /* Card 3: Progress bar animation */
  [data-progress-bar] {
    width: 0%;
    transition: width 600ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Subtle scroll-triggered animation */
  @media (prefers-reduced-motion: no-preference) {
    .outcome-card {
      opacity: 0;
      animation: subtleFadeUp 0.5s ease-out forwards;
    }

    .outcome-card:nth-child(2) {
      animation-delay: 0.1s;
    }

    .outcome-card:nth-child(3) {
      animation-delay: 0.2s;
    }

    .outcome-card:nth-child(4) {
      animation-delay: 0.3s;
    }
  }

  @keyframes subtleFadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Respect reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .outcome-card {
      opacity: 1 !important;
      animation: none !important;
    }
    
    [data-progress-bar] {
      width: 100% !important;
      transition: none !important;
    }
  }
</style>
