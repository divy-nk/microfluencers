---
import { logos } from 'virtual:starlight/user-images';
import config from 'virtual:starlight/user-config';

const authBaseUrl =
	import.meta.env.PUBLIC_WASP_ORIGIN ||
	(import.meta.env.DEV ? 'http://localhost:3000' : 'https://api.brandklip.com');

const dashboardHref = new URL('/dashboard', authBaseUrl).toString();

const href = Astro.site
const { siteTitle } = Astro.props;
---
<a {href} class="site-title sl-flex">
	{
		config.logo && logos.dark && (
			<>
				<img
					class:list={{ 'light:sl-hidden': !('src' in config.logo) }}
					alt={config.logo.alt}
					src={logos.dark.src}
					width={logos.dark.width}
					height={logos.dark.height}
				/>
				{!('src' in config.logo) && (
					<img
						class="dark:sl-hidden"
						alt={config.logo.alt}
						src={logos.light?.src}
						width={logos.light?.width}
						height={logos.light?.height}
					/>
				)}
			</>
		)
	}
	<span class:list={{ 'sr-only': config.logo?.replacesTitle }}>
		{siteTitle}
	</span>
</a>

<nav class="site-links" aria-label="Primary">
	<a href="/creators">For Creators</a>
	<a href="/contact">Contact</a>
	<a href="/blog">Blogs</a>
</nav>

<a href={dashboardHref} class="dashboard-link">Dashboard</a>

<style>
	.site-title {
		justify-self: flex-start;
		max-width: 100%;
		overflow: hidden;
		align-items: center;
		color: rgba(13, 13, 13, 0.92);
		gap: 0.5rem;
		font-size: 1.1rem;
		font-weight: 600;
		text-decoration: none;
		white-space: nowrap;
	}
	img {
		height: 1.75rem;
		width: auto;
		max-width: 100%;
		object-fit: contain;
		object-position: 0 50%;
	}

	.site-links {
		align-items: center;
		display: none;
		gap: 1.25rem;
		margin-left: 2rem;
  }

  @media (min-width: 50rem) {
		.site-links {
      display: flex;
    }

		.dashboard-link {
			display: inline-flex;
		}
  }

	.site-links a {
		color: rgba(13, 13, 13, 0.76);
		font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
  }

	.site-links a:hover {
		color: rgba(13, 13, 13, 0.92);
	}

	.dashboard-link {
		display: none;
		margin-left: auto;
		align-items: center;
		justify-content: center;
		height: 2.1rem;
		padding: 0 0.95rem;
		border-radius: 999px;
		background: #0d0d0d;
		color: #ffffff;
		font-size: 0.84rem;
		font-weight: 600;
		text-decoration: none;
	}

	.dashboard-link:hover {
		background: #000000;
	}

	@media (max-width: 50rem) {
		.site-title span {
			display: none;
		}
	}
</style>