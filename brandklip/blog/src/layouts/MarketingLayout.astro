---
import "../styles/tailwind.css";
import "../styles/animations.css";
import Nav from "../components/marketing/Nav.astro";

type Props = {
  title: string;
  description: string;
  canonicalPath: string;
  ogType?: "website" | "article";
  articleDate?: string;
  robots?: string;
  jsonLd?: Record<string, unknown>[];
};

const {
  title,
  description,
  canonicalPath,
  ogType = "website",
  articleDate,
  robots = "index,follow",
  jsonLd = [],
} = Astro.props;

const siteName = "BrandKlip";
const siteUrl = "https://www.brandklip.com";
const organizationId = `${siteUrl}/#organization`;
const websiteId = `${siteUrl}/#website`;
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const pageTitle = `${siteName} | ${title}`;
const ogImage = `${siteUrl}/BrandKlip%20OG%20Image.png`;
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": organizationId,
  name: "BrandKlip",
  alternateName: ["Brand Klip", "BrandKlip UGC"],
  legalName: "BrandKlip",
  url: siteUrl,
  logo: `${siteUrl}/brandklip-mint-logo.png`,
  description:
    "BrandKlip is an escrow-backed UGC platform for D2C brands in India, focused on approval-first creator payouts.",
  contactPoint: [
    {
      "@type": "ContactPoint",
      contactType: "customer support",
      email: "hello@brandklip.com",
      availableLanguage: ["English"],
    },
  ],
  sameAs: [
    "https://www.linkedin.com/company/brandklip/",
    "https://www.instagram.com/usebrandklip",
    "https://x.com/brandklip",
  ],
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": websiteId,
  name: "BrandKlip",
  alternateName: ["Brand Klip", "BrandKlip UGC"],
  url: siteUrl,
  publisher: {
    "@id": organizationId,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="author" content="BrandKlip" />
    <meta name="application-name" content="BrandKlip" />
    <meta name="apple-mobile-web-app-title" content="BrandKlip" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="BrandKlip" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="BrandKlip - Zero Risk UGC" />
    {articleDate && <meta property="article:published_time" content={articleDate} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@brandklip" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script>
      const w = window as any;
      w.dataLayer = w.dataLayer || [];

      const bkGtag = (...args: unknown[]) => {
        w.dataLayer.push(args);
      };

      bkGtag('js', new Date());

      // Defer analytics script so it doesn't compete with first paint/LCP.
      const loadGtag = () => {
        if (w.__bkGtagLoaded) return;
        w.__bkGtagLoaded = true;

        const script = document.createElement("script");
        script.async = true;
        script.src = "https://www.googletagmanager.com/gtag/js?id=G-SKBZLTYCVJ";
        document.head.appendChild(script);

        bkGtag('config', 'G-SKBZLTYCVJ');
      };

      if (typeof w.requestIdleCallback === "function") {
        w.requestIdleCallback(loadGtag, { timeout: 2500 });
      } else {
        globalThis.setTimeout(loadGtag, 1500);
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/brandklip-logo.svg" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="apple-touch-icon" href="/brandklip-mint-logo.png" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    {jsonLd.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles/marketing.css" />

    <script>
      const routeWindow = window as any;
      const normalizedPath = window.location.pathname.replace(/\/+$/, "") || "/";
      const knownRoutes = new Set([
        "/",
        "/about",
        "/blog",
        "/contact",
        "/creators",
        "/pricing",
        "/privacypolicy",
        "/terms",
      ]);

      const isKnownRoute =
        knownRoutes.has(normalizedPath) || normalizedPath.startsWith("/blog/");

      // App Platform fallback serves homepage HTML for unknown paths. Flag unknown paths for runtime 404 rendering.
      if (!isKnownRoute) {
        routeWindow.__bkUnknownRoute = normalizedPath;
      }
    </script>
  </head>
  <body>
    <Nav />
    <main class="relative z-10">
      <slot />
    </main>
    <script>
      const routeWindow = window as any;
      const unknownPath = routeWindow.__bkUnknownRoute;
      if (unknownPath) {
        document.title = "BrandKlip | Page Not Found";

        const robotsMeta = document.querySelector('meta[name="robots"]');
        if (robotsMeta) {
          robotsMeta.setAttribute("content", "noindex,follow");
        }

        const canonical = document.querySelector('link[rel="canonical"]');
        if (canonical) {
          canonical.setAttribute("href", "https://www.brandklip.com/404");
        }

        const main = document.querySelector("main");
        if (main) {
          main.innerHTML = `
            <section class="relative z-10 min-h-[70vh] flex items-center justify-center px-6 py-24">
              <div class="w-full max-w-3xl text-center">
                <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[var(--ink-45)] mb-5">Error 404</p>
                <h1 class="text-4xl md:text-6xl font-semibold tracking-tight text-[var(--brand-black)] mb-6 leading-tight">
                  Wrong endpoint.
                </h1>
                <p class="text-lg text-[var(--ink-60)] max-w-2xl mx-auto mb-10">
                  The page you requested does not exist.
                </p>
                <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
                  <a href="/" class="hero-cta hero-cta-static">Back to Homepage</a>
                  <a href="/contact" class="hero-cta" style="background: transparent; color: var(--brand-black); border: 1px solid var(--line-soft);">Contact Support</a>
                </div>
              </div>
            </section>
          `;
        }
      }
    </script>
    <script>
      const w = window as any;
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const isTouchDevice =
        window.matchMedia("(pointer: coarse)").matches ||
        navigator.maxTouchPoints > 0;
      const revealNodes = Array.from(document.querySelectorAll("[data-reveal]"));

      const showAllRevealNodes = () => {
        revealNodes.forEach((node) => {
          if (node instanceof HTMLElement) {
            node.style.opacity = "1";
            node.style.transform = "none";
          }
        });
      };

      const startLenis = async () => {
        if (w.__bkLenisStarted) return;
        w.__bkLenisStarted = true;

        const { default: Lenis } = await import("lenis");
        const lenis = new Lenis({
          smoothWheel: true,
          syncTouch: false,
          infinite: false,
          wheelMultiplier: 0.9,
          touchMultiplier: 0.9,
          duration: 0.9,
        });

        let rafId = 0;
        const raf = (time: number) => {
          lenis.raf(time);
          rafId = requestAnimationFrame(raf);
        };

        const onVisibility = () => {
          if (document.hidden) {
            cancelAnimationFrame(rafId);
            return;
          }
          rafId = requestAnimationFrame(raf);
        };

        const teardown = () => {
          cancelAnimationFrame(rafId);
          document.removeEventListener("visibilitychange", onVisibility);
          lenis.destroy();
          if (w.__bkLenis === lenis) {
            delete w.__bkLenis;
          }
          delete w.__bkLenisStarted;
        };

        w.__bkLenis = lenis;
        document.addEventListener("visibilitychange", onVisibility);
        window.addEventListener("pagehide", teardown, { once: true });
        rafId = requestAnimationFrame(raf);
      };

      const startGsapReveal = async () => {
        if (!revealNodes.length) return;

        if (prefersReducedMotion || isTouchDevice) {
          showAllRevealNodes();
          return;
        }

        const gsapModule = await import("gsap");
        const stModule = await import("gsap/ScrollTrigger");
        const gsap = gsapModule.gsap || gsapModule.default || gsapModule;
        const ScrollTrigger = stModule.ScrollTrigger || stModule.default;

        if (!gsap || !ScrollTrigger) {
          showAllRevealNodes();
          return;
        }

        gsap.registerPlugin(ScrollTrigger);

        const lenis = w.__bkLenis;
        if (lenis && !w.__bkLenisScrollTriggerBound) {
          lenis.on("scroll", ScrollTrigger.update);
          w.__bkLenisScrollTriggerBound = true;
        }

        revealNodes.forEach((node) => {
          if (!(node instanceof HTMLElement)) return;
          if (node.closest(".home-hero")) return;

          const variant = node.getAttribute("data-reveal-variant") || "fadeUp";
          const delay = Number.parseFloat(node.getAttribute("data-reveal-delay") || "0") || 0;

          let animation: Record<string, unknown> = { y: 26, autoAlpha: 0 };
          if (variant === "fadeLeft") animation = { x: -34, autoAlpha: 0 };
          if (variant === "fadeRight") animation = { x: 34, autoAlpha: 0 };
          if (variant === "scale") animation = { scale: 0.95, autoAlpha: 0 };
          if (variant === "blur") animation = { filter: "blur(8px)", autoAlpha: 0 };

          gsap.from(node, {
            ...animation,
            duration: 0.62,
            delay,
            ease: "power2.out",
            immediateRender: false,
            clearProps: "opacity,transform,filter,visibility",
            scrollTrigger: {
              trigger: node,
              start: "top 86%",
              once: true,
              fastScrollEnd: true,
            },
          });
        });
      };

      const boot = () => {
        if (!prefersReducedMotion && !isTouchDevice) {
          startLenis();
        }

        startGsapReveal();
      };

      if (document.readyState === "complete") {
        boot();
      } else {
        window.addEventListener("load", boot, { once: true });
      }
    </script>

    <script is:inline>
      const EXTERNAL_ICON = `
        <span class="bk-external-link__icon" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 5H11V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M10.9 5.1L5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
      `;

      const shouldEnhanceExternalLink = (anchor) => {
        if (anchor.hasAttribute("data-no-external-icon")) {
          return false;
        }

        const href = anchor.getAttribute("href");
        if (!href) return false;

        if (
          href.startsWith("#") ||
          href.startsWith("mailto:") ||
          href.startsWith("tel:") ||
          href.startsWith("javascript:")
        ) {
          return false;
        }

        try {
          const url = new URL(href, window.location.origin);
          return url.origin !== window.location.origin;
        } catch {
          return false;
        }
      };

      const enhanceExternalLinks = () => {
        const anchors = document.querySelectorAll("a[href]");

        anchors.forEach((anchor) => {
          if (!shouldEnhanceExternalLink(anchor)) return;

          anchor.classList.add("bk-external-link");

          if (!anchor.querySelector(".bk-external-link__icon")) {
            anchor.insertAdjacentHTML("beforeend", EXTERNAL_ICON);
          }

          if (anchor.getAttribute("target") === "_blank") {
            const rel = (anchor.getAttribute("rel") || "").split(/\s+/).filter(Boolean);
            if (!rel.includes("noopener")) rel.push("noopener");
            if (!rel.includes("noreferrer")) rel.push("noreferrer");
            anchor.setAttribute("rel", rel.join(" "));
          }
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", enhanceExternalLinks);
      } else {
        enhanceExternalLinks();
      }
    </script>
  </body>
</html>
